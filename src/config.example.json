{
    "baseURL": "https://rewards.bing.com",
    "sessionPath": "sessions",
    "headless": true,
    "clusters": 1,
    "errorDiagnostics": false,
    "ensureStreakProtection": true,
    "workers": {
        "doDailySet": true,
        "doClaimBonusPoints": true,
        "doSpecialPromotions": true,
        "doMorePromotions": true,
        "doPunchCards": true,
        "doAppPromotions": true,
        "doDesktopSearch": true,
        "doMobileSearch": true,
        "doDailyCheckIn": true,
        "doReadToEarn": true
    },
    "searchOnBingLocalQueries": false,
    "globalTimeout": "50sec",
    "searchSettings": {
        "scrollRandomResults": true,
        "clickRandomResults": true,
        "parallelSearching": false,
        "queryEngines": [
            "china",
            "local"
        ],
        "searchResultVisitTime": "20sec",
        "searchDelay": {
            "min": "6min",
            "max": "12min"
        },
        "readDelay": {
            "min": "6min",
            "max": "11min"
        },
        "chinaApi": {
            "appkey": ""
        }
    },
    "debugLogs": true,
    "consoleLogFilter": {
        "enabled": false,
        "mode": "whitelist",
        "levels": [
            "error",
            "warn"
        ],
        "keywords": [
            "starting account"
        ],
        "regexPatterns": []
    },
    "proxy": {
        "queryEngine": false
    },
    "webhook": {
        "pushplus": {
            "enabled": false,
            "token": "",
            "title": "Microsoft-Rewards-Script",
            "template": "html"
        },
        "webhookLogFilter": {
            "enabled": false,
            "mode": "whitelist",
            "levels": [
                "error"
            ],
            "keywords": [
                "starting account",
                "select number",
                "collected"
            ],
            "regexPatterns": []
        }
    }
}
